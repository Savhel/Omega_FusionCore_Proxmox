{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "omega-remote-paging — RAM paging cluster overview",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Pages mémoire",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": { "lineWidth": 2 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (node_id) (omega_pages_evicted_total)",
          "legendFormat": "évincées — {{node_id}}",
          "refId": "A"
        },
        {
          "expr": "sum by (node_id) (omega_pages_recalled_total)",
          "legendFormat": "rappelées — {{node_id}}",
          "refId": "B"
        }
      ],
      "title": "Pages évincées / rappelées (total cumulé)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "sum by (node_id) (omega_page_faults_total)",
          "legendFormat": "faults — {{node_id}}",
          "refId": "A"
        }
      ],
      "title": "Page faults uffd (total cumulé)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "targets": [
        {
          "expr": "sum by (node_id) (omega_pages_stored)",
          "legendFormat": "pages stockées — {{node_id}}",
          "refId": "A"
        }
      ],
      "title": "Pages actuellement sur les stores",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "decbytes", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "targets": [
        {
          "expr": "omega_store_estimated_bytes",
          "legendFormat": "octets — {{node_id}}",
          "refId": "A"
        }
      ],
      "title": "Occupation mémoire stores (bytes estimés)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 101,
      "title": "CPU / vCPU",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0, "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 5,
      "targets": [
        {
          "expr": "omega_vcpu_current",
          "legendFormat": "vCPUs actifs — vm {{vm_id}}",
          "refId": "A"
        }
      ],
      "title": "vCPUs actifs par VM (hotplug élastique)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 6,
      "targets": [
        {
          "expr": "omega_vcpu_utilization_pct",
          "legendFormat": "utilisation vCPU — vm {{vm_id}}",
          "refId": "A"
        },
        {
          "expr": "omega_cpu_pressure_pct",
          "legendFormat": "pression CPU hôte — {{node_id}}",
          "refId": "B"
        }
      ],
      "title": "Utilisation vCPU et pression CPU hôte",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "id": 102,
      "title": "Disque / Ceph",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": 0 },
              { "color": "yellow", "value": 5000 },
              { "color": "green",  "value": 20000 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 27 },
      "id": 7,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto" },
      "targets": [
        {
          "expr": "omega_disk_available_mib",
          "legendFormat": "dispo — {{node_id}}",
          "refId": "A"
        }
      ],
      "title": "Espace disque disponible par store (MiB)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "bool", "color": { "mode": "fixed", "fixedColor": "blue" } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 27 },
      "id": 8,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "omega_ceph_enabled",
          "legendFormat": "Ceph — {{node_id}}",
          "refId": "A"
        }
      ],
      "title": "Ceph activé (auto-détecté)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 27 },
      "id": 9,
      "targets": [
        {
          "expr": "omega_pages_orphaned_deleted_total",
          "legendFormat": "orphelins supprimés — {{node_id}}",
          "refId": "A"
        }
      ],
      "title": "Pages orphelines supprimées (total)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "id": 103,
      "title": "Réseau / Réplication",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "id": 10,
      "targets": [
        {
          "expr": "rate(omega_store_puts_total[1m])",
          "legendFormat": "PUT/s — {{node_id}}",
          "refId": "A"
        },
        {
          "expr": "rate(omega_store_gets_total[1m])",
          "legendFormat": "GET/s — {{node_id}}",
          "refId": "B"
        }
      ],
      "title": "Débit store (PUT/GET par seconde)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "id": 11,
      "targets": [
        {
          "expr": "omega_store_hit_rate",
          "legendFormat": "hit rate — {{node_id}}",
          "refId": "A"
        }
      ],
      "title": "Taux de hit store (recall cache hit)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["omega", "proxmox", "memory", "paging"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(omega_pages_stored, node_id)",
        "label": "Nœud store",
        "name": "node_id",
        "options": [],
        "query": "label_values(omega_pages_stored, node_id)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "omega-remote-paging",
  "uid": "omega-remote-paging-v1",
  "version": 1
}
